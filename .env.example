# Browser app config
# Copy config.example.js to config.js for local testing.

# Server-side backup/restore config.
# Never put these values in src/App.jsx or index.html.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
BACKUP_GPG_PASSPHRASE=replace-with-a-long-random-passphrase

# Optional off-site backup storage. Works with AWS S3 or S3-compatible services
# such as Cloudflare R2 if you configure endpoint support in the workflow.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BACKUP_BUCKET=
AWS_BACKUP_PREFIX=student-tracker
